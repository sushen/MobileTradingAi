<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.shaplachottor.app.fragments.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_phasesFragment"
            app:destination="@id/phasesFragment" />
    </fragment>

    <fragment
        android:id="@+id/phasesFragment"
        android:name="com.shaplachottor.app.fragments.PhasesFragment"
        android:label="Learning Phases"
        tools:layout="@layout/fragment_phases">
        <action
            android:id="@+id/action_phasesFragment_to_classroomFragment"
            app:destination="@id/classroomFragment" />
    </fragment>

    <fragment
        android:id="@+id/classroomFragment"
        android:name="com.shaplachottor.app.fragments.ClassroomFragment"
        android:label="Classroom"
        tools:layout="@layout/fragment_classroom">
        <argument
            android:name="phaseId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/educationFragment"
        android:name="com.shaplachottor.app.fragments.EducationFragment"
        android:label="@string/title_courses"
        tools:layout="@layout/fragment_education" />

    <fragment
        android:id="@+id/myLearningFragment"
        android:name="com.shaplachottor.app.fragments.MyLearningFragment"
        android:label="@string/title_my_learning"
        tools:layout="@layout/fragment_my_learning" >
        <action
            android:id="@+id/action_myLearningFragment_to_phasesFragment"
            app:destination="@id/phasesFragment" />
        <action
            android:id="@+id/action_myLearningFragment_to_classroomFragment"
            app:destination="@id/classroomFragment" />
    </fragment>

    <fragment
        android:id="@+id/advancedFragment"
        android:name="com.shaplachottor.app.fragments.AdvancedFragment"
        android:label="@string/title_advanced"
        tools:layout="@layout/fragment_advanced" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.shaplachottor.app.fragments.ProfileFragment"
        android:label="@string/title_profile"
        tools:layout="@layout/fragment_profile" />

    <!-- Secondary fragments accessible from Advanced -->
    <fragment
        android:id="@+id/installFragment"
        android:name="com.shaplachottor.app.fragments.InstallFragment"
        android:label="Install Bot"
        tools:layout="@layout/fragment_install" />

    <fragment
        android:id="@+id/investFragment"
        android:name="com.shaplachottor.app.fragments.InvestFragment"
        android:label="Invest"
        tools:layout="@layout/fragment_invest" />

    <fragment
        android:id="@+id/affiliateFragment"
        android:name="com.shaplachottor.app.fragments.AffiliateFragment"
        android:label="Affiliate"
        tools:layout="@layout/fragment_affiliate" />

</navigation>
